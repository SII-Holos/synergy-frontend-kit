{
  "name": "synergy-frontend-kit",
  "version": "0.2.0",
  "type": "module",
  "main": "./src/index.ts",
  "scripts": {
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "sync:skills": "bash scripts/update.sh",
    "verify:skills": "bun run scripts/verify-skill-bundles.ts",
    "validate:manifest": "bun run scripts/validate-manifest.ts",
    "validate:plugin": "synergy-plugin validate --runtime-discovery",
    "build:plugin": "synergy-plugin build",
    "pack:plugin": "synergy-plugin pack",
    "sign:plugin": "synergy-plugin sign",
    "entry:plugin": "synergy-plugin entry",
    "publish:market": "synergy-plugin publish-market",
    "release:check": "bun run verify:skills && bun run validate:manifest && bun run typecheck && bun test && bun run validate:plugin && bun run build:plugin && bun run pack:plugin"
  },
  "peerDependencies": {
    "@ericsanchezok/synergy-plugin": "^2.2.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@ericsanchezok/synergy-plugin-kit": "^2.2.2",
    "@ericsanchezok/synergy-plugin": "^2.2.0",
    "@types/bun": "^1.3.14",
    "solid-js": "^1.9.10",
    "typescript": "^6.0.3",
    "zod": "^4.4.3"
  }
}
